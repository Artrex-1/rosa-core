# Rosa-Core API Configuration
PORT=3100

# API Keys (comma-separated) for Rosa instances
# Generate a unique key per instance with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In docker-compose these are assembled from ROSA_CORE_API_KEY and ROSA_LAPTOP_API_KEY
API_KEYS=chat-rosa-key-here,laptop-rosa-key-here

# Names corresponding to API_KEYS (same order)
API_KEY_NAMES=chat-rosa,laptop-rosa

# Webhook: stuur notificaties bij task status wijzigingen naar rosa-telegram
# URL naar de webhook endpoint van rosa-telegram
TASK_WEBHOOK_URL=http://localhost:3200/webhook/task-complete
# Gedeeld secret voor authenticatie (moet overeenkomen met WEBHOOK_SECRET in rosa-telegram)
TASK_WEBHOOK_SECRET=rosa-webhook-secret-change-me

# Development mode — stel in op 'true' om zonder API keys te draaien
# NOOIT in productie gebruiken
# ROSA_DEV_MODE=true

# Workspace root voor /files routes (VERPLICHT — geen default meer)
WORKSPACE_ROOT=/pad/naar/je/workspace

# Sentry error tracking (optional)
SENTRY_DSN=
